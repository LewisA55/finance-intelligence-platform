{
  "name": "atlas-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Project Atlas - CFO Finance Intelligence dashboard (React + DuckDB-WASM, static).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "refresh-data": "node scripts/refresh-data.mjs",
    "manifest-data": "node scripts/data-manifest.mjs",
    "validate-data": "node scripts/validate-data.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "check": "npm run validate-data && npm run build"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright-core": "^1.57.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.16"
  }
}
